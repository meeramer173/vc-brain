# LLM for the intelligence layer (axis agents, validator, memo). Required only
# for memo generation; the whole data spine (sourcing, scoring, backtest) runs
# without it.
OPENAI_API_KEY=

# Optional: which OpenAI model the intelligence layer uses (default: gpt-5-mini)
OPENAI_MODEL=

# Optional: raises the GitHub connector's rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# Required only for the `tavily` enrichment source (web/press signals per
# founder). Bearer token from tavily.com — free tier is 1000 credits/month.
TAVILY_API_KEY=

# Demo access gate (HTTP Basic Auth). Set BOTH on the deployment to require a
# login for everyone; leave unset locally to run without a gate. Share these
# with judges in the submission — never commit real values here.
DEMO_USER=
DEMO_PASSWORD=
