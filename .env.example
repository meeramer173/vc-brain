# LLM for the intelligence layer (axis agents, validator, memo). Required only
# for memo generation; the whole data spine (sourcing, scoring, backtest) runs
# without it.
OPENAI_API_KEY=

# Optional: which OpenAI model the intelligence layer uses (default: gpt-5-mini)
OPENAI_MODEL=

# Optional: raises the GitHub connector's rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=
